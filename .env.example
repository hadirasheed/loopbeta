# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API). On Vercel, set the same variables.

# Safe to expose to the browser (NEXT_PUBLIC_ prefix):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. MUST NOT have the NEXT_PUBLIC_ prefix — it bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of emails allowed into /admin (checked server-side).
ADMIN_EMAILS=you@example.com

# Server-only secret used to encrypt LLM provider API keys at rest (AES-256-GCM).
# Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-random-secret

# Base URL of the deployed site, used for OAuth redirects.
# http://localhost:3000 locally; your Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
